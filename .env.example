# Copy to .env.local for `vercel dev`, or set these in the Vercel dashboard
# under Project -> Settings -> Environment Variables. Never commit real values.

# Required — server-side only, never exposed to the browser.
ANTHROPIC_API_KEY=

# Optional — locks the /api/chat proxy to your real domain(s), comma-separated.
# Leave unset for your first deploy; set it once you know your URL.
ALLOWED_ORIGINS=

# Optional — enables per-IP rate limiting on /api/chat. Free tier at upstash.com.
# Leave unset to run unthrottled (fine for local dev / early testing).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
